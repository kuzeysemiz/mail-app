# Production Environment Variables
# Bu dosyayı .env olarak kopyalayıp güvenli bilgiler ekleyin

# Backend Configuration
PORT=5000
NODE_ENV=production

# Gmail Configuration
GMAIL_EMAIL=your-email@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Database
DATABASE_URL=sqlite:///mail_scheduler.db

# Logging
LOG_LEVEL=info

# Security
CORS_ORIGIN=https://yourdomain.com
API_RATE_LIMIT=100

# Optional: PM2 Configuration
PM2_MAX_MEMORY_RESTART=500M
PM2_INSTANCES=max
